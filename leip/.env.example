# LEIP Environment Configuration
# Copy to .env and configure for your deployment

# ============ DATABASE ============
DATABASE_URL=postgresql://leip_user:secure_password@localhost:5432/leip_db
DATABASE_POOL_SIZE=20
DATABASE_ECHO_SQL=false

# ============ FACE RECOGNITION ============
FACE_MODEL_NAME=ArcFace
FACE_SIMILARITY_THRESHOLD=0.6
FACE_EMBEDDING_DIM=512
FACE_DETECTOR_BACKEND=retinaface
MAX_FACES_PER_IMAGE=10

# ============ YOLO DETECTION ============
YOLO_MODEL_SIZE=medium
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45
YOLO_DEVICE=cpu
YOLO_BACKEND=ultralytics
YOLO_ONNX_PATH=yolov8m.onnx
YOLO_CLASS_NAMES=coco.names
YOLO_ONNX_INPUT_SIZE=640
YOLO_RUST_PERSISTENT=true

# ============ LICENSE PLATE RECOGNITION ============
LPR_ENGINE=easyocr
LPR_CONFIDENCE_THRESHOLD=0.4
LPR_BATCH_SIZE=32

# ============ VECTOR SEARCH (FAISS) ============
FAISS_INDEX_TYPE=HNSW
FAISS_HNSW_M=32
FAISS_HNSW_EF_CONSTRUCTION=200
FAISS_HNSW_EF_SEARCH=100
FAISS_GPU_ENABLED=false

# ============ API SERVER ============
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4
SECRET_KEY=change-me-to-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FILE=logs/leip.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=json

# ============ STORAGE ============
UPLOAD_DIR=data/uploads
TEMP_DIR=data/temp
MODEL_CACHE_DIR=models/cache
MAX_FILE_SIZE_MB=500

# ============ CCTV PROCESSING ============
CCTV_FRAME_SKIP=5
CCTV_BATCH_SIZE=16
CCTV_BUFFER_SIZE=100
CCTV_TIMEOUT_SECONDS=30

# ============ KAFKA (Real-time Streams) ============
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_DETECTION_TOPIC=leip_detections
KAFKA_MATCH_TOPIC=leip_matches

# ============ SECURITY & AUTH ============
ENABLE_RBAC=true
ENABLE_API_KEY_AUTH=true
ALLOW_CORS_ORIGINS=http://localhost:3000,http://localhost:8501
SESSION_TIMEOUT_MINUTES=30
PASSWORD_MIN_LENGTH=12
REQUIRE_2FA=false

# ============ EXTERNAL INTEGRATIONS ============
GOOGLE_MAPS_API_KEY=your-api-key-here
SOCIAL_MEDIA_API_KEYS={}
HOSPITAL_API_ENDPOINT=https://hospital-api.example.com
UNIVERSITY_API_ENDPOINT=https://university-api.example.com

# ============ MONITORING ============
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_METRICS=true

# ============ DEVELOPMENT ============
DEBUG_MODE=false
TESTING_MODE=false
MOCK_EXTERNAL_SERVICES=false
